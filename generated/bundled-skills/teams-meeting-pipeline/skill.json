{
  "schemaVersion": "prometheus-skill-bundle-v1",
  "id": "teams-meeting-pipeline",
  "name": "teams-meeting-pipeline",
  "description": "Build a Microsoft Graph-backed Teams meeting pipeline for meeting discovery, transcript or recording ingestion, action extraction, follow-up drafting, and explicit task sync. Use when implementing Teams meeting integration or processing Teams meeting data with user intent.",
  "version": "1.0.0",
  "entrypoint": "SKILL.md",
  "implicitInvocation": true,
  "triggers": [
    "teams follow up workflow",
    "teams meeting pipeline",
    "microsoft teams connector",
    "teams meeting transcript",
    "teams recording ingestion",
    "teams meeting actions"
  ],
  "categories": [
    "prometheus",
    "integrations",
    "connectors",
    "meetings"
  ],
  "requiredTools": [
    "web_search",
    "web_fetch",
    "web_fetch_batch",
    "connector_list",
    "terminal"
  ],
  "permissions": {
    "workspaceRead": true,
    "workspaceWrite": true,
    "externalSideEffects": true
  },
  "lifecycle": "active"
}
