{
  "schemaVersion": "prometheus-skill-bundle-v1",
  "id": "airtable-connector",
  "name": "airtable-connector",
  "description": "Build, operate, or harden a schema-aware Airtable connector for bases, tables, fields, record queries, exports, and confirmed writes. Use when a request explicitly concerns Airtable integration or Airtable record operations; do not use for generic database or spreadsheet work.",
  "version": "1.1.0",
  "entrypoint": "SKILL.md",
  "implicitInvocation": true,
  "triggers": [
    "airtable record search",
    "airtable base schema",
    "airtable table schema",
    "export airtable records",
    "create airtable record",
    "update airtable record",
    "airtable integration",
    "airtable connector",
    "connect airtable",
    "airtable api"
  ],
  "categories": [
    "prometheus",
    "integrations",
    "connectors",
    "database"
  ],
  "requiredTools": [
    "web_search",
    "web_fetch",
    "web_fetch_batch",
    "connector_list",
    "terminal"
  ],
  "permissions": {
    "workspaceRead": true,
    "workspaceWrite": true,
    "externalSideEffects": true
  },
  "lifecycle": "active"
}
