{
  "schemaVersion": "prometheus-skill-bundle-v1",
  "id": "trello-connector",
  "name": "trello-connector",
  "description": "Build or operate a Trello connector for boards, lists, cards, labels, comments, checklists, movement, and explicit Prometheus task links. Use when a request specifically concerns Trello integration or Trello card operations; do not invoke for generic task planning.",
  "version": "1.0.0",
  "entrypoint": "SKILL.md",
  "implicitInvocation": true,
  "triggers": [
    "trello board integration",
    "create trello card",
    "trello card tools",
    "move trello card",
    "trello task sync",
    "trello connector"
  ],
  "categories": [
    "prometheus",
    "integrations",
    "connectors",
    "project-management"
  ],
  "requiredTools": [
    "web_search",
    "web_fetch",
    "web_fetch_batch",
    "connector_list",
    "terminal"
  ],
  "permissions": {
    "workspaceRead": true,
    "workspaceWrite": true,
    "externalSideEffects": true
  },
  "lifecycle": "active"
}
