{
  "schemaVersion": "prometheus-skill-bundle-v1",
  "id": "cli-adapter-framework",
  "name": "cli-adapter-framework",
  "description": "Build or harden a typed Prometheus adapter around an external command-line tool, including status checks, bounded actions, artifacts, cancellation, and side-effect controls. Use when explicitly wrapping or exposing a CLI; do not use for ordinary shell commands.",
  "version": "1.1.0",
  "entrypoint": "SKILL.md",
  "implicitInvocation": true,
  "triggers": [
    "expose cli in prometheus",
    "add command line tool",
    "external cli integration",
    "wrap external cli",
    "safe cli wrapper",
    "harden shell workflow",
    "typed shell tool",
    "cli connector",
    "cli adapter"
  ],
  "categories": [
    "prometheus",
    "integrations",
    "cli",
    "tooling"
  ],
  "requiredTools": [
    "terminal",
    "connector_list"
  ],
  "permissions": {
    "workspaceRead": true,
    "workspaceWrite": true,
    "shell": true,
    "externalSideEffects": true
  },
  "lifecycle": "active"
}
