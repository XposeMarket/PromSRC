{
  "schemaVersion": "prometheus-skill-bundle-v1",
  "id": "interactive-visuals",
  "name": "interactive-visuals",
  "description": "Route /visual and general visualization requests to exactly one best-fit chart, Mermaid, SVG, or interactive HTML visual skill.",
  "version": "2.1.0",
  "entrypoint": "SKILL.md",
  "triggers": [
    "/visual",
    "visualize this",
    "turn this into a visual",
    "show this visually",
    "make a diagram",
    "make this interactive"
  ],
  "categories": [
    "visuals",
    "router",
    "cards",
    "dashboards"
  ],
  "requiredTools": ["skills"],
  "permissions": {},
  "resources": [
    {
      "path": "references/soul-visual-defaults.md",
      "type": "doc",
      "description": "When to use which visual skill; migrated from SOUL Visuals section"
    }
  ],
  "implicitInvocation": true,
  "lifecycle": "active"
}
