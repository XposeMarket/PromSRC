{
  "schemaVersion": "prometheus-skill-bundle-v1",
  "id": "discord-connector",
  "name": "discord-connector",
  "description": "Build or extend a Discord bot or OAuth connector with typed server, channel, thread, message, member, and moderation tools. Use when implementing or hardening Discord integration in Prometheus; do not invoke for generic social-media work.",
  "version": "1.0.0",
  "entrypoint": "SKILL.md",
  "implicitInvocation": true,
  "triggers": [
    "build discord connector",
    "discord oauth integration",
    "discord channel tools",
    "discord message connector",
    "connect discord bot",
    "discord connector"
  ],
  "categories": [
    "prometheus",
    "integrations",
    "connectors",
    "community"
  ],
  "requiredTools": [
    "web_search",
    "web_fetch",
    "web_fetch_batch",
    "connector_list",
    "terminal"
  ],
  "permissions": {
    "workspaceRead": true,
    "workspaceWrite": true,
    "externalSideEffects": true
  },
  "lifecycle": "active"
}
