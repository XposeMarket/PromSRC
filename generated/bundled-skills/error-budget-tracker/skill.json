{
  "schemaVersion": "prometheus-skill-bundle-v1",
  "entrypoint": "SKILL.md",
  "description": "Log and analyze tool or workflow failures, unresolved errors, repeated timeouts, rate limits, reliability patterns, and error-budget reports. Use when the user asks what keeps failing or wants structured operational failure evidence.",
  "triggers": [
    "system health budget",
    "service level objective",
    "too many failures",
    "operational reliability",
    "reliability budget",
    "reliability report",
    "incident tracker",
    "regression rate",
    "incident count",
    "flaky failures",
    "track failures",
    "failure budget"
  ],
  "categories": [
    "reliability",
    "operations",
    "metrics"
  ],
  "requiredTools": [
    "workspace_write",
    "show_ui_card"
  ],
  "lifecycle": "active",
  "name": "error-budget-tracker",
  "id": "error-budget-tracker",
  "implicitInvocation": true
}
