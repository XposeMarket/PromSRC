{
  "schemaVersion": "prometheus-skill-bundle-v1",
  "id": "webhook-receiver-framework",
  "name": "webhook-receiver-framework",
  "description": "Use when configuring or extending Prometheus inbound webhook endpoints, including authenticated wake events and agent dispatch. Do not invoke for ordinary API calls or outbound integrations.",
  "version": "2.0.0",
  "entrypoint": "SKILL.md",
  "triggers": [
    "configure inbound webhook",
    "receive signed webhook",
    "github webhook receiver",
    "stripe webhook receiver",
    "slack webhook receiver",
    "webhook signature verification",
    "webhook replay protection",
    "test webhook receiver"
  ],
  "categories": [
    "prometheus",
    "integrations",
    "events",
    "architecture"
  ],
  "requiredTools": [
    "integration_admin"
  ],
  "permissions": {
    "workspaceRead": true,
    "workspaceWrite": true,
    "externalSideEffects": true
  },
  "implicitInvocation": true,
  "lifecycle": "active"
}
