{
  "schemaVersion": "prometheus-skill-bundle-v1",
  "id": "linear-connector",
  "name": "linear-connector",
  "description": "Build or operate a vault-backed Linear GraphQL connector for teams, projects, issues, cycles, comments, statuses, and explicit task synchronization. Use when a request specifically concerns Linear integration or Linear issue operations; do not invoke for generic task planning.",
  "version": "1.0.0",
  "entrypoint": "SKILL.md",
  "implicitInvocation": true,
  "triggers": [
    "create linear issue from prometheus",
    "linear issue integration",
    "linear graphql connector",
    "update linear issue",
    "linear project sync",
    "linear connector"
  ],
  "categories": [
    "prometheus",
    "integrations",
    "connectors",
    "project-management"
  ],
  "requiredTools": [
    "web_search",
    "web_fetch",
    "web_fetch_batch",
    "connector_list",
    "terminal"
  ],
  "permissions": {
    "workspaceRead": true,
    "workspaceWrite": true,
    "externalSideEffects": true
  },
  "lifecycle": "active"
}
