{
  "schemaVersion": "prometheus-skill-bundle-v1",
  "id": "google-workspace-expansion",
  "name": "google-workspace-expansion",
  "description": "Extend Prometheus Google Workspace connectors for Calendar, Docs, Sheets, Drive, Gmail, or Contacts using OAuth-backed typed tools. Use when implementing or broadening Google Workspace integration; do not invoke for ordinary email, document, or spreadsheet content work.",
  "version": "1.0.0",
  "entrypoint": "SKILL.md",
  "implicitInvocation": true,
  "triggers": [
    "expand google workspace integration",
    "google workspace connector",
    "google calendar connector",
    "google docs connector",
    "google sheets connector",
    "gmail connector setup",
    "google contacts connector",
    "drive connector extension"
  ],
  "categories": [
    "prometheus",
    "integrations",
    "connectors",
    "productivity"
  ],
  "requiredTools": [
    "web_search",
    "web_fetch",
    "web_fetch_batch",
    "connector_list",
    "terminal"
  ],
  "permissions": {
    "workspaceRead": true,
    "workspaceWrite": true,
    "externalSideEffects": true
  },
  "lifecycle": "active"
}
