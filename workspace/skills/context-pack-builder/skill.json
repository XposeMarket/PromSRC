{
  "schemaVersion": "prometheus-skill-bundle-v1",
  "id": "context-pack-builder",
  "name": "context-pack-builder",
  "description": "Assemble reusable Prometheus briefing packs from memory, project and team context, sessions, files, and cited sources. Use only when the user explicitly asks for a context pack, briefing pack, or reusable agent handoff; do not invoke for ordinary prompt context.",
  "version": "1.0.0",
  "entrypoint": "SKILL.md",
  "implicitInvocation": false,
  "triggers": [
    "context pack builder",
    "client briefing pack",
    "project context pack",
    "reusable agent briefing",
    "workflow context bundle"
  ],
  "categories": [
    "prometheus",
    "memory",
    "agents",
    "context"
  ],
  "requiredTools": [
    "advanced_memory",
    "agents_and_teams",
    "workspace_write"
  ],
  "permissions": {
    "workspaceRead": true,
    "workspaceWrite": true
  },
  "resources": [
    {
      "path": "references/workflows/context-pack-builder.md",
      "type": "doc",
      "description": "Add workflow recipe to context-pack-builder"
    }
  ],
  "lifecycle": "active"
}
