    "compare this offer",
    "analyze this deal",
    "price value check",
    "value for money",
    "used item deal",
    "discount negotiation",
    "negotiate price"
  ],
  "categories": [],
  "requiredTools": [],
  "permissions": {},
  "resources": [
    {
      "path": "references/workflows/deal-analyzer.md",
      "type": "doc",
      "description": "Add workflow recipe to deal-analyzer"
    }
  ],
  "implicitInvocation": true,
  "lifecycle": "active"
}
