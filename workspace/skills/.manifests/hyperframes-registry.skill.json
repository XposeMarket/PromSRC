{
  "schemaVersion": "prometheus-skill-bundle-v1",
  "entrypoint": "SKILL.md",
  "id": "hyperframes-registry",
  "name": "HyperFrames Registry",
  "description": "Install and wire HyperFrames registry blocks/components. Prometheus should use catalog-first routing for captions, transitions, social UI, maps/charts, code snippets, VFX, device/app showcases, and logo outros before hand-authoring lookalikes.",
  "version": "1.1.0",
  "triggers": [
    "hyperframes registry",
    "hyperframes catalog",
    "hyperframes add",
    "caption component",
    "caption-style",
    "hyperframes component",
    "hyperframes block"
  ],
  "categories": [
    "creative",
    "video",
    "hyperframes",
    "catalog",
    "registry"
  ],
  "requiredTools": [
    "workspace_write"
  ],
  "permissions": {
    "workspaceRead": true,
    "workspaceWrite": true,
    "shell": true
  },
  "resources": [
    {
      "path": "references/current-catalog-snapshot-2026-06-04.md",
      "type": "reference",
      "description": "Fetched 2026-06-04 registry snapshot with category routing."
    },
    {
      "path": "references/discovery.md",
      "type": "reference",
      "description": "Registry discovery workflow."
    },
    {
      "path": "references/wiring-blocks.md",
      "type": "reference",
      "description": "How to wire block sub-compositions."
    },
    {
      "path": "references/wiring-components.md",
      "type": "reference",
      "description": "How to wire snippet components."
    },
    {
      "path": "examples/add-block.md",
      "type": "example",
      "description": "Block install example."
    },
    {
      "path": "examples/add-component.md",
      "type": "example",
      "description": "Component install example."
    }
  ]
}
