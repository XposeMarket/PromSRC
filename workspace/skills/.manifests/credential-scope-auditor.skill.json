{
  "schemaVersion": "prometheus-skill-bundle-v1",
  "entrypoint": "SKILL.md",
  "description": "Use this skill when the user asks to audit credential scopes, OAuth permissions, API token permissions, connector access, least-privilege settings, security posture, or whether a token has too much or too little access. It produces scope findings and safer recommendations.",
  "triggers": [
    "credential scope",
    "token scope",
    "OAuth permissions",
    "audit credentials",
    "least privilege",
    "API token permissions",
    "connector permissions",
    "security audit token",
    "access scope",
    "GitHub PAT scope",
    "permission review",
    "credential audit",
    "auth scopes",
    "token permissions",
    "scope auditor"
  ],
  "categories": [
    "security",
    "integrations",
    "audit"
  ],
  "requiredTools": [
    "connector_list",
    "external_apps",
    "integration_admin"
  ],
  "lifecycle": "active",
  "id": "credential-scope-auditor"
}
