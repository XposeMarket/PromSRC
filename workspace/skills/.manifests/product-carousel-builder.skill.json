{
  "schemaVersion": "prometheus-skill-bundle-v1",
  "entrypoint": "SKILL.md",
  "id": "product-carousel-builder",
  "name": "Product Carousel Builder",
  "description": "Reusable workflow for extracting, curating, and displaying product recommendations with Prometheus product carousels.",
  "version": "1.0.0",
  "triggers": [
    "product carousel",
    "show carousel",
    "shopping carousel",
    "amazon carousel",
    "product recommendations",
    "show products",
    "product cards",
    "find products",
    "shopping search",
    "compare products",
    "Amazon products",
    "popular products"
  ],
  "categories": [
    "shopping",
    "research",
    "browser",
    "visual-output"
  ],
  "requiredTools": [
    "browser_automation",
    "web",
    "skills"
  ],
  "resources": [
    {
      "path": "examples/amazon-mens-shampoo-carousel.md",
      "type": "example",
      "description": "Worked example based on an Amazon men’s shampoo search, including extraction fields and carousel curation logic.",
      "triggers": [
        "amazon shampoo",
        "men shampoo",
        "amazon carousel",
        "shopping carousel"
      ],
      "autoInject": true,
      "injectMode": "summary_then_content",
      "maxInjectChars": 3000
    }
  ],
  "toolBinding": {
    "requiredTools": [
      "browser_automation"
    ],
    "recommendedToolCategories": [
      "browser_automation"
    ],
    "defaultWorkflow": [
      "Extract candidates from product source",
      "Curate 3–8 distinct products",
      "Call show_product_carousel"
    ],
    "canSpawnSubagents": false
  },
  "permissions": {
    "browser": true,
    "workspaceRead": false,
    "workspaceWrite": false,
    "externalSideEffects": false
  },
  "status": "ready",
  "lifecycle": "active",
  "ownership": "prometheus-owned"
}
