{
  "schemaVersion": "prometheus-skill-bundle-v1",
  "entrypoint": "SKILL.md",
  "description": "Use when the user asks to find, compare, recommend, or display real purchasable products as product cards or a carousel. Do not use for non-shopping research or generic visual cards.",
  "triggers": [
    "find me a good",
    "ratings and reviews",
    "best laptop under",
    "buy this product",
    "under my budget",
    "product recommendations",
    "shopping comparison",
    "product carousel",
    "cheapest option",
    "compare prices",
    "review roundup",
    "best products"
  ],
  "categories": [
    "shopping",
    "research",
    "visualization"
  ],
  "requiredTools": [
    "shopping_search_products",
    "show_ui_card",
    "web_search"
  ],
  "lifecycle": "active",
  "id": "product-carousel-builder",
  "status": "ready",
  "implicitInvocation": true,
  "health": {
    "state": "ready",
    "reason": "A live DDG-backed product query returned a validated product record with a real product URL and usable image; incomplete cards and empty results remain fail-closed.",
    "verifiedCapabilities": [
      "live_product_provider",
      "product_payload_validation",
      "empty_result_rejection",
      "carousel_item_validation",
      "usable_product_url",
      "usable_product_image"
    ],
    "blockedCapabilities": {},
    "lastVerified": "2026-07-12"
  },
  "name": "product-carousel-builder"
}
