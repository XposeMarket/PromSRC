{
  "schemaVersion": "prometheus-skill-bundle-v1",
  "entrypoint": "SKILL.md",
  "description": "Use this skill when the task touches API keys, OAuth tokens, PATs, client secrets, environment credentials, connector secrets, vault references, auth failures caused by credentials, or credential rotation/revocation. It is not for generic API work unless secrets are involved.",
  "triggers": [
    "api key",
    "OAuth token",
    "personal access token",
    "PAT",
    "client secret",
    "rotate token",
    "revoke token",
    "credential leak",
    "leaked secret",
    "env var secret",
    ".env credentials",
    "connector secret",
    "vault reference",
    "bearer token",
    "auth token",
    "GitHub token",
    "X OAuth secret",
    "store this key safely",
    "mask the secret",
    "credential scope",
    "token expired",
    "refresh token"
  ],
  "categories": [
    "security",
    "secrets",
    "credentials",
    "auth"
  ],
  "requiredTools": [
    "connector_list",
    "external_apps",
    "integration_admin"
  ],
  "lifecycle": "active",
  "id": "secret-and-token-ops"
}
