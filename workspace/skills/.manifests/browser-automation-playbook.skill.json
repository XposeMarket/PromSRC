{
  "schemaVersion": "prometheus-skill-bundle-v1",
  "entrypoint": "SKILL.md",
  "description": "Use this skill when Prometheus needs to operate a website in a browser: open pages, click controls, fill forms, take browser screenshots, extract page text, upload/download files, run browser QA, or recover from dynamic web UI state.",
  "triggers": [
    "open this website",
    "use the browser",
    "click on the page",
    "fill this web form",
    "browser automation",
    "browser screenshot",
    "inspect this webpage",
    "extract page text",
    "login in browser",
    "upload file on website",
    "download from website",
    "test this web page",
    "check the live site",
    "use Chrome",
    "navigate the page",
    "scroll the webpage",
    "browser QA",
    "verify website UI"
  ],
  "categories": [
    "browser",
    "automation",
    "qa",
    "web"
  ],
  "requiredTools": [
    "browser_automation"
  ],
  "lifecycle": "active",
  "id": "browser-automation-playbook"
}
