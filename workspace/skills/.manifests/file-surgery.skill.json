{
  "schemaVersion": "prometheus-skill-bundle-v1",
  "entrypoint": "skill.md",
  "description": "Use this skill when the task requires inspecting, editing, patching, or verifying workspace files, markdown, configs, prompts, skills, docs, scripts, UI files, or source-adjacent assets. It is for concrete file mutation and verification work, not for generic mentions of code terms.",
  "triggers": [
    "edit this file",
    "update this file",
    "patch this file",
    "modify the markdown",
    "fix this config",
    "update the skill",
    "clean up this document",
    "replace these lines",
    "add a section",
    "remove a section",
    "inspect before editing",
    "verify the file change",
    "patch the repo",
    "make this file change",
    "update workspace docs",
    "edit the prompt file",
    "fix the script",
    "update generated docs",
    "change this json",
    "rewrite this markdown"
  ],
  "categories": [
    "files",
    "editing",
    "verification",
    "workspace",
    "skills"
  ],
  "requiredTools": [
    "workspace_write",
    "skills"
  ],
  "lifecycle": "active",
  "id": "file-surgery"
}
