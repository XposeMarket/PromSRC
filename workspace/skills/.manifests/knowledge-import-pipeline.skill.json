{
  "schemaVersion": "prometheus-skill-bundle-v1",
  "entrypoint": "SKILL.md",
  "description": "Use this skill when the user asks to import, ingest, organize, summarize, or convert external knowledge into Prometheus memory, skills, resources, docs, entity files, or workspace notes. It focuses on preserving source provenance and making knowledge reusable.",
  "triggers": [
    "knowledge import",
    "import docs",
    "ingest knowledge",
    "convert notes",
    "add to memory",
    "import resource",
    "organize knowledge",
    "knowledge pipeline",
    "save this knowledge",
    "turn into skill",
    "document source",
    "archive this",
    "import file",
    "knowledge base",
    "source provenance"
  ],
  "categories": [
    "knowledge-management",
    "memory",
    "documentation"
  ],
  "requiredTools": [
    "memory_search",
    "write_note",
    "file_ops",
    "skills"
  ],
  "lifecycle": "active",
  "id": "knowledge-import-pipeline"
}
