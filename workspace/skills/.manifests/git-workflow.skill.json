    "revert my change",
    "stash changes",
    "preserve dirty work",
    "sync the repo",
    "make a commit",
    "push the site",
    "resolve conflicts",
    "tag a release",
    "compare branches",
    "git workflow"
  ],
  "categories": [
    "git",
    "repo",
    "version-control"
  ],
  "requiredTools": [
    "workspace_write"
  ],
  "lifecycle": "active",
  "id": "git-workflow"
}
