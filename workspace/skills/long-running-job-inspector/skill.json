{
  "schemaVersion": "prometheus-skill-bundle-v1",
  "id": "long-running-job-inspector",
  "name": "long-running-job-inspector",
  "description": "Inspect, summarize, cancel, retry, or recover Prometheus background tasks, scheduled jobs, process runs, approvals, and stalled executions. Use when the user asks what is running or needs help with a specific active, stalled, or failed job.",
  "version": "1.0.0",
  "entrypoint": "SKILL.md",
  "implicitInvocation": true,
  "triggers": [
    "long running job status",
    "cancel running background task",
    "inspect running jobs",
    "background job inspector",
    "process run log",
    "stuck background task",
    "retry stalled task"
  ],
  "categories": [
    "prometheus",
    "tasks",
    "processes",
    "operations"
  ],
  "requiredTools": [
    "automations",
    "workspace_write"
  ],
  "permissions": {
    "workspaceRead": true,
    "workspaceWrite": true,
    "shell": true
  },
  "lifecycle": "active"
}
