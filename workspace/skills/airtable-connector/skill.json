{
  "schemaVersion": "prometheus-skill-bundle-v1",
  "id": "airtable-connector",
  "name": "Airtable Connector",
  "description": "Add Airtable bases, tables, fields, record search, record creation, updates, and exports as typed Prometheus connector tools.",
  "version": "1.0.0",
  "entrypoint": "SKILL.md",
  "triggers": [
    "airtable connector",
    "airtable base",
    "airtable records",
    "update airtable",
    "airtable table"
  ],
  "categories": [
    "prometheus",
    "integrations",
    "connectors",
    "database"
  ],
  "requiredTools": [
    "web_search",
    "web_fetch",
    "web_fetch_batch",
    "connector_list",
    "terminal"
  ],
  "permissions": {
    "workspaceRead": true,
    "workspaceWrite": true,
    "externalSideEffects": true
  }
}
