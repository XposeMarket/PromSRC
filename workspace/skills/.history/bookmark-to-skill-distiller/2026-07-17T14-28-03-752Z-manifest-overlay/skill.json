{
  "schemaVersion": "prometheus-skill-bundle-v1",
  "id": "bookmark-to-skill-distiller",
  "name": "Bookmark-to-Skill Distiller",
  "description": "Audit X bookmarks or saved-link corpora, extract repeated operational workflows, compare them with the installed Prometheus skill catalog, and produce ranked evidence-backed new-skill and improvement recommendations. Use for bookmark audits and saved-idea operationalization.",
  "version": "1.0.0",
  "entrypoint": "SKILL.md",
  "triggers": [],
  "categories": [
    "skills",
    "research",
    "x",
    "knowledge-management",
    "audit"
  ],
  "requiredTools": [
    "browser_automation",
    "workspace_write",
    "skills"
  ],
  "implicitInvocation": true,
  "permissions": {
    "browser": true,
    "workspaceRead": true,
    "workspaceWrite": true,
    "externalSideEffects": false
  },
  "resources": [
    {
      "path": "templates/scoring-rubric.md",
      "type": "template",
      "description": "Scoring table"
    },
    {
      "path": "examples/raul-x-bookmarks-audit.md",
      "type": "example",
      "description": "Canonical worked example pointer"
    },
    {
      "path": "references/trigger-tests.md",
      "type": "test",
      "description": "Routing tests"
    }
  ]
}
