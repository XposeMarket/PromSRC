# ============================================================
# Prometheus - .gitignore
# ============================================================

# --- DOCKER / ENV ---
.env

# --- SECRETS & CONFIG (NEVER COMMIT) ---
.localclaw/config.json
.localclaw/credentials/
.localclaw/vault/
/.prometheus/

# --- RUNTIME DATA ---
.localclaw/sessions/
.localclaw/logs/
.localclaw/memory/
.localclaw/facts.json
.localclaw/self_learning.json
.localclaw/jobs.db
.localclaw/update_state.json
.localclaw/tasks/
.localclaw/jobs/
.localclaw/ocr-cache/
.localclaw/heartbeat/
.localclaw/task-heartbeat.json
.localclaw/cron/runs/

# --- WORKSPACE RUNTIME FILES ---
# Keep: SOUL.md, SELF.md, IDENTITY.md, USER.md, MEMORY.md, AGENTS.md, TOOLS.md, BOOT.md, README.md
# These are default templates that ship with Prometheus; new users need them.
# Ignore: daily memory logs, tool audit log, heartbeat, and any AI-generated scratch files.
workspace/memory/
workspace/.prometheus/
workspace/audit/
workspace/downloads/
workspace/uploads/
workspace/Brain/
workspace/entities/
workspace/events/
workspace/integrations/
workspace/projects/
workspace/proposals/
workspace/tasks/
workspace/teams/
workspace/lead-research
workspace/lead-research/
workspace/Prometheus Website/
workspace/oss-agents/
workspace/tool_audit.log
workspace/HEARTBEAT.md
workspace/note.txt
workspace/*.html
workspace/*.js
workspace/*.css
workspace/*.py
workspace/*.sh
workspace/*.bat
workspace/*.txt
workspace/xposemarket-site/
teams/team_mn74d1g9_0f4d45/workspace/_github_prometheus_upload

# --- DASHBOARD RUNTIME STATE ---
ai-dashboard/dashboard-state.json
ai-dashboard/dashboard-requests.json

# --- LOGS ---
gateway.log
gateway.err.log
*.log

# --- TEMP FILES ---
tmp_payload.json
mnt/
/.claude/settings.local.json
/.vscode/settings.json
/.pip-cache/
/.pip-tmp/
/.tmp-py/
__pycache__/
*.pyc
.tmp_*
.tmp_*/
.tmp_openclaw_*/
.tmp_codex_*
tmp_*
fix_log_line.py

# --- LOCAL PLANNING / HANDOFF ARTIFACTS ---
/CIS.docx
/Prometheus_CIS_Plan.docx
/Prometheus_Teams_CIS_Master_Plan.docx
/prometheus_browser_intelligence.docx
/skills.zip
/Context.md
/PROPOSALS_ANALYSIS.md
/Prometheus_Teams_CIS_Master_Plan.md
/apply-local-llm-patch.js
/b5-server-v2.js
/write-chat-helpers.js
/patch-server-v2.js
/rebrand-html.js
/rebrand-src.js
/test-ollama.mjs
/check-build.bat
/start-gateway.bat

# --- LOCAL BINARY / MODEL ARTIFACTS ---
/bin/ffmpeg/
*.onnx
*.gguf
*.safetensors

# --- RUNTIME FILES THAT MUST NEVER ENTER SOURCE ---
src/**/*.log
src/**/*.md.bak
src/**/memory/*.md
workspace/memory/

# --- NODE ---
node_modules/
/dist/
*.js.map
/package/
*.tgz

# --- TEST ARTIFACTS ---
tests/.golden-progress.log

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- ELECTRON BUILD OUTPUT ---
/release/
/release-public/
/output/
/tmp/
