workspace/uploads/**
workspace/entities/**
workspace/events/**
workspace/integrations/**
workspace/projects/**
workspace/proposals/**
workspace/tasks/**
workspace/node_modules/
workspace/logs/
workspace/tmp/
workspace/creative-projects/
workspace/generated/**

# Raul's self docs are intentionally tracked in full.
!workspace/self/
!workspace/self/**

# Keep skeleton folders in clones while excluding their bulky contents.
!workspace/.prometheus/
!workspace/.prometheus/**/
!workspace/.prometheus/**/.gitkeep
!workspace/oss-agents/.gitkeep
