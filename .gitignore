# ============================================================
# Prometheus - .gitignore
# ============================================================

# --- DOCKER / ENV ---
.env

# --- SECRETS & CONFIG (NEVER COMMIT) ---
.localclaw/config.json
.localclaw/credentials/
.localclaw/vault/
/.prometheus/
/.prometheus-dev-*/
/.agents/
/.claude/
/Brain/

# --- RUNTIME DATA ---
.localclaw/sessions/
.localclaw/logs/
.localclaw/memory/
.localclaw/facts.json
.localclaw/self_learning.json
.localclaw/jobs.db
.localclaw/update_state.json
.localclaw/tasks/
.localclaw/jobs/
.localclaw/ocr-cache/
.localclaw/heartbeat/
.localclaw/task-heartbeat.json
.localclaw/cron/runs/

# --- DASHBOARD RUNTIME STATE ---
ai-dashboard/dashboard-state.json
ai-dashboard/dashboard-requests.json

# --- LOGS ---
gateway.log
gateway.err.log
*.log

# --- TEMP FILES ---
tmp_payload.json
mnt/
/.claude/settings.local.json
/.vscode/settings.json
/.npmrc
/.gateway-*.cjs
/.pip-cache/
/.pip-tmp/
/.tmp-py/
__pycache__/
*.pyc
.tmp_*
.tmp_*/
.tmp_openclaw_*/
.tmp_codex_*
tmp_*
fix_log_line.py

# --- LOCAL PLANNING / HANDOFF ARTIFACTS ---
/CIS.docx
/Prometheus_CIS_Plan.docx
/Prometheus_Teams_CIS_Master_Plan.docx
/prometheus_browser_intelligence.docx
/skills.zip
/Context.md
/PROPOSALS_ANALYSIS.md
/Prometheus_Teams_CIS_Master_Plan.md
/apply-local-llm-patch.js
/b5-server-v2.js
/write-chat-helpers.js
/patch-server-v2.js
/rebrand-html.js
/rebrand-src.js
/test-ollama.mjs
/check-build.bat
/start-gateway.bat
/HEARTBEAT.md
/PROMETHEUS_HTML_MOTION_BACKEND_HANDOFF.md
/PROMETHEUS_VIDEO_CREATIVE_UPGRADE_PLAN.md
/Prometheus_Team_Room_Refinement_Plan.md
/prometheus_creative_suite_plan.md
/hook-library.skill
/-Context
/*.docx
/*.mp4
/*.png
/eng.traineddata

# --- LOCAL BINARY / MODEL ARTIFACTS ---
/bin/ffmpeg/
*.onnx
*.gguf
*.safetensors

# --- RUNTIME FILES THAT MUST NEVER ENTER SOURCE ---
src/**/*.log
src/**/*.md.bak
src/**/memory/*.md

# --- NODE ---
node_modules/
/dist/
*.js.map
/package/
*.tgz

# --- TEST ARTIFACTS ---
tests/.golden-progress.log

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- ELECTRON BUILD OUTPUT ---
/release/
/release-public/
/output/
/tmp/

# --- PERSONAL WORKSPACE SYNC ---
# Workspace contents are intentionally Git-visible for Raul's own sync.
# The public Electron package excludes workspace via electron-builder-public.yml.
!workspace/
!workspace/**
!workspace/**/

# Bulky workspace projects/runtime folders are kept local and rebuilt/redone as needed.
workspace/oss-agents/
workspace/Prometheus Website/
workspace/xposemarket-site/
workspace/xpose-market/
workspace/teams/
workspace/.prometheus/**
workspace/.prometheus/subagents/
workspace/hyperframes/
workspace/hyperframes-promo-test/
workspace/fitpulse-real-hyperframes/
workspace/assets/
workspace/video-debug/
workspace/opportunity-radar/
workspace/signal-radar/
workspace/Brain/
