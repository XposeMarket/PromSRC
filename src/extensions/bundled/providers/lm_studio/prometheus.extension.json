{
  "id": "lm_studio",
  "kind": "provider",
  "name": "LM Studio",
  "description": "Local LM Studio endpoint using the OpenAI-compatible API surface.",
  "category": "Local",
  "enabledByDefault": true,
  "docsUrl": "https://lmstudio.ai/",
  "tags": ["local", "lm studio", "openai-compatible"],
  "runtime": {
    "binding": "providers/openai-compat-adapter"
  },
  "ui": {
    "color": "#0F766E"
  },
  "ownership": {
    "providerIds": ["lm_studio"],
    "capabilities": ["llm", "local_inference", "openai_compat"]
  },
  "setup": {
    "authType": "none",
    "statusMode": "generic"
  },
  "config": {
    "defaults": {
      "endpoint": "http://localhost:1234",
      "model": ""
    },
    "schema": {
      "endpoint": "string",
      "model": "string",
      "api_key": "string?"
    },
    "uiHints": {
      "endpoint": {
        "label": "Endpoint",
        "help": "LM Studio local server URL."
      },
      "model": {
        "label": "Model",
        "help": "Default model to use from LM Studio."
      },
      "api_key": {
        "label": "API Key",
        "help": "Optional auth token if LM Studio is configured to require one."
      }
    }
  }
}
