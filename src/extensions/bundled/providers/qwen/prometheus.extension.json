{
  "id": "qwen",
  "kind": "provider",
  "name": "Qwen Cloud",
  "description": "Qwen and DashScope models through the compatible-mode API.",
  "category": "Hosted",
  "enabledByDefault": true,
  "docsUrl": "https://www.alibabacloud.com/help/en/model-studio/",
  "tags": ["qwen", "dashscope", "alibaba", "openai-compatible"],
  "runtime": {
    "binding": "providers/openai-compat-adapter",
    "options": {
      "chatCompletionsPath": "/chat/completions",
      "modelsPath": "/models",
      "staticModels": ["qwen3.5-plus", "qwen3-coder-plus", "qwen3-coder-next", "glm-5", "MiniMax-M2.5"],
      "supportsLiveModelDiscovery": true
    }
  },
  "ui": {
    "color": "#D97706"
  },
  "ownership": {
    "providerIds": ["qwen"],
    "modelPrefixes": ["qwen", "MiniMax-", "glm-"],
    "capabilities": ["llm", "api_key_auth", "openai_compat"]
  },
  "setup": {
    "authType": "api_key",
    "envVars": ["QWEN_API_KEY", "MODELSTUDIO_API_KEY", "DASHSCOPE_API_KEY"],
    "statusMode": "generic",
    "fields": [
      {
        "key": "api_key",
        "label": "API Key",
        "input": "password",
        "required": true,
        "secret": true,
        "placeholder": "dashscope-..."
      },
      {
        "key": "model",
        "label": "Model",
        "input": "text",
        "required": true,
        "placeholder": "qwen3.5-plus"
      },
      {
        "key": "endpoint",
        "label": "Endpoint Override",
        "input": "text",
        "placeholder": "https://dashscope-intl.aliyuncs.com/compatible-mode/v1"
      }
    ]
  },
  "config": {
    "defaults": {
      "endpoint": "https://dashscope-intl.aliyuncs.com/compatible-mode/v1",
      "model": "qwen3.5-plus"
    },
    "schema": {
      "api_key": "string",
      "endpoint": "string?",
      "model": "string"
    }
  }
}
