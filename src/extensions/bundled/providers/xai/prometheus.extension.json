{
  "id": "xai",
  "kind": "provider",
  "name": "xAI",
  "description": "xAI Grok models via API key or Grok account OAuth.",
  "category": "Hosted",
  "enabledByDefault": true,
  "docsUrl": "https://docs.x.ai/",
  "tags": ["xai", "grok", "openai-compatible"],
  "runtime": {
    "binding": "providers/openai-compat-adapter",
    "options": {
      "chatCompletionsPath": "/chat/completions",
      "modelsPath": "/models",
      "staticModels": [
        "grok-4.5",
        "grok-composer-2.5-fast",
        "grok-4.3",
        "grok-4.3-latest",
        "grok-latest",
        "grok-4.20-0309-reasoning",
        "grok-4.20-0309-non-reasoning",
        "grok-4.20-multi-agent-0309",
        "grok-4.20-multi-agent",
        "grok-build-0.1"
      ],
      "supportsLiveModelDiscovery": true,
      "supportsReasoningEffort": true
    }
  },
  "ui": {
    "color": "#111827"
  },
  "ownership": {
    "providerIds": ["xai"],
    "modelPrefixes": ["grok-"],
    "tools": ["x_search", "xai_live_search"],
    "capabilities": ["llm", "api_key_auth", "openai_compat", "image_generation", "video_generation"]
  },
  "setup": {
    "authType": "api_key",
    "envVars": ["XAI_API_KEY", "XAI_MODEL", "XAI_IMAGE_MODEL", "XAI_VIDEO_MODEL"],
    "statusMode": "generic",
    "fields": [
      {
        "key": "auth_mode",
        "label": "Auth Mode",
        "input": "select",
        "options": ["api_key", "oauth"],
        "required": true,
        "help": "Use api_key for direct xAI API billing, or oauth to use a connected Grok account/subscription token."
      },
      {
        "key": "api_key",
        "label": "API Key",
        "input": "password",
        "required": false,
        "secret": true,
        "placeholder": "xai-...",
        "help": "Optional when Auth Mode is oauth."
      },
      {
        "key": "model",
        "label": "Model",
        "input": "text",
        "required": true,
        "placeholder": "grok-4.3"
      },
      {
        "key": "reasoning_effort",
        "label": "Reasoning Effort",
        "input": "select",
        "options": ["", "none", "low", "medium", "high", "xhigh"],
        "required": false,
        "help": "Blank uses xAI default. Sent only for effort-capable Grok chat models such as grok-4.3, grok-4.5, and grok-4.20-multi-agent; unsupported models omit it to avoid xAI request errors."
      },
      {
        "key": "endpoint",
        "label": "Endpoint Override",
        "input": "text",
        "placeholder": "https://api.x.ai/v1"
      }
    ]
  },
  "config": {
    "defaults": {
      "endpoint": "https://api.x.ai/v1",
      "auth_mode": "api_key",
      "model": "grok-4.3",
      "reasoning_effort": ""
    },
    "schema": {
      "auth_mode": "string",
      "api_key": "string",
      "endpoint": "string?",
      "model": "string",
      "reasoning_effort": "string?"
    }
  }
}
