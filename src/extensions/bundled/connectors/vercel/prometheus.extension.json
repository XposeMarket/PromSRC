{
  "id": "vercel",
  "kind": "connector",
  "name": "Vercel",
  "description": "Connect Vercel so Prometheus can detect projects, trigger deployments, and surface preview URLs.",
  "category": "Dev",
  "enabledByDefault": true,
  "docsUrl": "https://vercel.com/account/tokens",
  "tags": ["vercel", "deployments", "api key"],
  "runtime": {
    "binding": "integrations/connectors/vercel",
    "entrypoint": "./runtime.js"
  },
  "ui": {
    "color": "#111111",
    "permissions": [
      { "icon": "^", "label": "Create and link Vercel projects" },
      { "icon": "->", "label": "Trigger deployments from the canvas" },
      { "icon": "?", "label": "Read deployment state and live URLs" }
    ]
  },
  "ownership": {
    "toolNamespaces": ["connector_vercel"],
    "capabilities": ["deployments", "hosting", "projects", "environment"],
    "tools": [
      "connector_vercel_status",
      "connector_vercel_list_teams",
      "connector_vercel_list_projects",
      "connector_vercel_list_deployments",
      "connector_vercel_get_deployment",
      "connector_vercel_redeploy",
      "connector_vercel_env",
      "connector_vercel_domains"
    ]
  },
  "setup": {
    "authType": "api_key",
    "statusMode": "generic",
    "docsUrl": "https://vercel.com/account/tokens",
    "docsHint": "Vercel -> Account Settings -> Tokens. Project ID is optional; omit it for account/team-wide tools. Team ID is optional and scopes team-owned resources.",
    "fields": [
      {
        "key": "apiKey",
        "label": "API Token",
        "input": "password",
        "required": true,
        "secret": true,
        "placeholder": "vercel_pat_..."
      },
      {
        "key": "projectId",
        "label": "Project ID",
        "input": "text",
        "required": false,
        "placeholder": "prj_..."
      },
      {
        "key": "teamId",
        "label": "Team ID",
        "input": "text",
        "required": false,
        "placeholder": "team_..."
      }
    ]
  }
}
