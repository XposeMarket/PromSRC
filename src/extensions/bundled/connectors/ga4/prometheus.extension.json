{
  "id": "ga4",
  "kind": "connector",
  "name": "Google Analytics 4",
  "description": "Connect GA4 so Prometheus can pull traffic, conversions, realtime usage, and report data.",
  "category": "Analytics",
  "enabledByDefault": true,
  "docsUrl": "https://console.cloud.google.com/",
  "tags": ["ga4", "analytics", "oauth"],
  "runtime": {
    "binding": "integrations/connectors/google-analytics"
  },
  "ui": {
    "color": "#F59E0B",
    "permissions": [
      { "icon": "=", "label": "Read sessions, pageviews, and conversions" },
      { "icon": "?", "label": "Query custom reports and events" },
      { "icon": "!", "label": "Read-only analytics access" }
    ]
  },
  "ownership": {
    "toolNamespaces": ["connector_ga4"],
    "capabilities": ["analytics", "traffic", "reports"],
    "tools": [
      "connector_ga4_run_report",
      "connector_ga4_realtime_users",
      "connector_ga4_list_properties"
    ]
  },
  "setup": {
    "authType": "oauth",
    "statusMode": "oauth_connector",
    "docsUrl": "https://console.cloud.google.com/",
    "docsHint": "Google Cloud Console -> Enable Analytics Data API -> Desktop app credentials. Also set your GA4 property ID.",
    "fields": [
      {
        "key": "clientId",
        "label": "Client ID",
        "input": "text",
        "required": true,
        "placeholder": "123456789-abc.apps.googleusercontent.com"
      },
      {
        "key": "clientSecret",
        "label": "Client Secret",
        "input": "password",
        "required": true,
        "secret": true,
        "placeholder": "GOCSPX-..."
      }
    ]
  }
}
