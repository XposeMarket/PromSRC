{
  "id": "gmail",
  "kind": "connector",
  "name": "Gmail",
  "description": "Connect Gmail so Prometheus can read inbox threads, draft replies, send email, and work with attachments.",
  "category": "Email",
  "enabledByDefault": true,
  "docsUrl": "https://console.cloud.google.com/",
  "tags": ["google", "email", "oauth"],
  "runtime": {
    "binding": "integrations/connectors/gmail"
  },
  "ui": {
    "color": "#EA4335",
    "permissions": [
      { "icon": "@", "label": "Read inbox and thread history" },
      { "icon": "->", "label": "Draft and send emails with approval" },
      { "icon": "?", "label": "Search emails by sender, subject, or keyword" },
      { "icon": "[]", "label": "Read and download attachments" }
    ]
  },
  "ownership": {
    "toolNamespaces": ["connector_gmail"],
    "capabilities": ["email", "inbox", "attachments"],
    "tools": [
      "connector_gmail_list_emails",
      "connector_gmail_get_email",
      "connector_gmail_send_email",
      "connector_gmail_get_profile",
      "connector_gmail_list_labels"
    ]
  },
  "setup": {
    "authType": "oauth",
    "statusMode": "oauth_connector",
    "docsUrl": "https://console.cloud.google.com/",
    "docsHint": "Google Cloud Console -> Enable Gmail API -> OAuth 2.0 credentials -> Desktop app.",
    "callback": {
      "port": 19421,
      "path": "/auth/callback/gmail"
    },
    "fields": [
      {
        "key": "clientId",
        "label": "Client ID",
        "input": "text",
        "required": true,
        "placeholder": "123456789-abc.apps.googleusercontent.com"
      },
      {
        "key": "clientSecret",
        "label": "Client Secret",
        "input": "password",
        "required": true,
        "secret": true,
        "placeholder": "GOCSPX-..."
      }
    ]
  }
}
