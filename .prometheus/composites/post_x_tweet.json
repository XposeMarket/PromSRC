{
  "name": "post_x_tweet",
  "description": "Compose and post a tweet on X (Twitter). Opens X in the browser, fills in the tweet text, and publishes it.",
  "parameters": {
    "tweet_text": {
      "type": "string",
      "description": "The tweet content to post"
    }
  },
  "steps": [
    {
      "tool": "browser_open",
      "args": {
        "url": "https://x.com/home"
      }
    },
    {
      "tool": "browser_click",
      "args": {
        "selector": "[aria-label='Post']"
      }
    },
    {
      "tool": "browser_fill",
      "args": {
        "selector": "[data-testid='tweetTextarea_0']",
        "text": "{{tweet_text}}"
      }
    },
    {
      "tool": "browser_click",
      "args": {
        "selector": "[data-testid='tweetButton']"
      }
    }
  ]
}