{
  "name": "prometheus",
  "version": "1.0.1",
  "description": "Prometheus — Local AI automation layer. Run and manage entire operations with a single intelligent agent.",
  "main": "electron/main.js",
  "bin": {
    "prom": "./bin/prometheus.js"
  },
  "scripts": {
    "build": "tsc",
    "patch:electron-native": "node scripts/patch-electron-native-deps.js",
    "prepare:public": "node scripts/prepare-public-build.js",
    "dev": "tsx src/cli/index.ts",
    "start": "tsx src/cli/index.ts",
    "gateway": "tsx src/cli/index.ts gateway start",
    "cli:link": "npm run build && npm link",
    "cli:unlink": "npm unlink -g prometheus",
    "lint": "eslint src --ext .ts",
    "start:compiled": "node dist/cli/index.js",
    "electron": "electron .",
    "build:win": "npm run patch:electron-native && electron-builder --win --config electron-builder.yml",
    "build:public": "npm run build && npm run prepare:public && npm run patch:electron-native && electron-builder --win --config electron-builder-public.yml",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "ai",
    "agent",
    "ollama",
    "automation",
    "prometheus",
    "context-injection"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.4.0",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "cors": "^2.8.6",
    "croner": "^10.0.1",
    "docx": "^8.5.0",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "mammoth": "^1.8.0",
    "mermaid": "^11.13.0",
    "node-pty": "^1.1.0",
    "ollama": "^0.5.0",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.58.2",
    "tesseract.js": "^5.1.1",
    "ws": "^8.16.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.0",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "eslint": "^8.57.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
