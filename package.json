{
  "name": "prometheus",
  "version": "1.0.9",
  "description": "Prometheus — Local AI automation layer. Run and manage entire operations with a single intelligent agent.",
  "main": "electron/main.js",
  "bin": {
    "prom": "./bin/prometheus.js"
  },
  "scripts": {
    "build": "npm run build:backend && npm run build:web",
    "build:backend": "tsc && node scripts/copy-creative-renderers.js && node scripts/copy-runtime-prompt-assets.js",
    "build:web": "npm run check:web-ui",
    "check:web-ui": "node scripts/check-public-web-ui-sync.js",
    "sync:web-ui": "node scripts/prepare-public-build.js --web-only && npm run check:web-ui",
    "sync:hyperframes": "node scripts/sync-hyperframes-catalog.js",
    "test:hyperframes-roundtrip": "node scripts/test-hyperframes-roundtrip.mjs",
    "test:hyperframes-catalog": "npm run build:backend && node scripts/test-hyperframes-catalog-pipeline.mjs",
    "test:runtime-prompt-manifest": "tsx src/runtime/prompt-manifest.regression.ts",
    "test:tool-category-manifest": "tsx src/runtime/tool-category-manifest.regression.ts",
    "test:tool-category-phase4": "tsx src/runtime/tool-category-phase4.validation.ts",
    "test:instruction-segment-resolver": "tsx src/runtime/instruction-segment-registry.regression.ts",
    "test:instruction-intent-benchmark": "tsx src/runtime/instruction-intent-benchmark.regression.ts",
    "test:stage4-menu-pilot": "tsx src/runtime/stage4-menu-pilot.regression.ts",
    "test:skill-routing-benchmark": "tsx src/runtime/skill-routing-benchmark.regression.ts",
    "test:pairing-admin-boundary": "npm run build:backend && node scripts/test-pairing-admin-boundary.mjs",
    "test:storage-boundaries": "npm run build:backend && node scripts/test-storage-boundaries.mjs",
    "test:subagent-context": "npm run build:backend && node scripts/test-subagent-context-isolation.mjs",
    "test:agent-identity-memory": "npm run build:backend && node scripts/test-agent-identity-memory.mjs",
    "test:codex-spark-usage": "npm run build:backend && node scripts/test-codex-spark-usage.mjs",
    "test:untrusted-content-boundary": "npm run build && node scripts/test-untrusted-content-boundary.mjs",
    "test:electron-security-boundary": "node scripts/test-electron-security-boundary.mjs",
    "test:skill-curator-pipeline": "npm run build:backend && node scripts/test-skill-curator-pipeline.mjs",
    "test:skill-routing": "npm run build:backend && node scripts/test-skill-routing.mjs",
    "test:skill-catalog": "npm run build:backend && node scripts/test-live-skill-catalog.mjs",
    "test:skill-structure": "npm run build:backend && node scripts/test-skill-catalog-structure.mjs",
    "test:skill-revamp": "npm run build:backend && node scripts/test-skill-revamp-closeout.mjs",
    "test:desktop": "npm run build:backend && node scripts/test-desktop-registry-parity.mjs && node scripts/test-desktop-state-contract.mjs",
    "test:browser": "npm run build:backend && node scripts/test-browser-contract.mjs && node scripts/test-tool-benchmark-aggregate.mjs",
    "test:workspace-tools": "npm run build:backend && node scripts/test-workspace-process-health.mjs",
    "test:integrations": "npm run build:backend && node scripts/test-integration-runtime-contract.mjs",
    "test:connections": "npm run build:backend && node scripts/test-connection-orchestrator.mjs",
    "test:agents": "npm run build:backend && node scripts/test-agent-runtime-contract.mjs",
    "test:automations": "npm run build:backend && node scripts/test-automation-runtime-contract.mjs",
    "test:reasoning-capabilities": "npm run build:backend && node scripts/test-reasoning-capabilities.mjs",
    "test:work-narrative": "npm run build:backend && node scripts/test-work-narrative-stream.mjs",
    "test:goal-restart": "npm run build:backend && node scripts/test-main-chat-goal-restart-contract.mjs && node scripts/test-main-chat-goal-steer-contract.mjs",
    "test:mobile-recovery": "node scripts/test-mobile-chat-recovery.mjs",
    "benchmark:desktop": "npm run build:backend && node scripts/benchmark-desktop.mjs",
    "build:desktop-helper:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-desktop-helper-win.ps1",
    "patch:hyperframes-esm": "node scripts/patch-hyperframes-esm.mjs",
    "test:creative-command-bus": "npm run build && node scripts/test-creative-command-bus.js",
    "postbuild": "node scripts/copy-extension-descriptors.js",
    "patch:electron-native": "node scripts/patch-electron-native-deps.js",
    "prepare:public": "node scripts/prepare-public-build.js",
    "prepare:public-web": "node scripts/prepare-public-build.js --web-only",
    "bundle:public-skills": "node scripts/prepare-public-build.js --skills-only",
    "test:public-skills": "npm run bundle:public-skills && node scripts/test-public-skill-bundle.mjs",
    "dev": "tsx src/cli/index.ts",
    "start": "tsx src/cli/index.ts",
    "gateway": "tsx src/cli/index.ts gateway start",
    "lint": "eslint src --ext .ts",
    "start:compiled": "node dist/cli/index.js",
    "electron": "electron .",
    "build:win": "npm run patch:electron-native && electron-builder --win --config electron-builder.yml",
    "verify:public-release": "node scripts/verify-public-release.js",
    "build:public": "npm run build:backend && node scripts/copy-extension-descriptors.js && npm run prepare:public-web && npm run check:web-ui && npm run patch:electron-native && electron-builder --win --config electron-builder-public.yml && npm run verify:public-release",
    "release": "npm run build:public && electron-builder --win --config electron-builder-public.yml --prepackaged release-public/win-unpacked --publish=always",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "ai",
    "agent",
    "ollama",
    "automation",
    "prometheus",
    "context-injection"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@chenglou/pretext": "^0.0.5",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/manrope": "^5.2.8",
    "@hyperframes/core": "^0.6.20",
    "@hyperframes/engine": "^0.6.20",
    "@hyperframes/player": "^0.6.20",
    "@hyperframes/producer": "^0.6.20",
    "@hyperframes/studio": "^0.6.20",
    "@iconify/iconify": "^3.1.1",
    "@lottiefiles/dotlottie-web": "0.77.1",
    "@lottiefiles/lottie-player": "^2.0.12",
    "@remotion/bundler": "^4.0.451",
    "@remotion/renderer": "^4.0.451",
    "@types/web-push": "^3.6.4",
    "archiver": "^5.3.2",
    "better-sqlite3": "^11.4.0",
    "chalk": "^4.1.2",
    "chart.js": "^4.5.1",
    "codemirror": "^5.65.16",
    "commander": "^12.0.0",
    "cors": "^2.8.6",
    "croner": "^10.0.1",
    "docx": "^8.5.0",
    "dompurify": "^3.3.3",
    "dotenv": "^16.4.0",
    "electron-updater": "^6.8.3",
    "express": "^4.18.0",
    "fluent-ffmpeg": "^2.1.3",
    "gif.js": "^0.2.0",
    "gsap": "3.15.0",
    "hyperframes": "^0.6.20",
    "jimp": "^0.22.12",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "linkedom": "^0.18.12",
    "mammoth": "^1.8.0",
    "marked": "^9.1.6",
    "mermaid": "^11.13.0",
    "node-pty": "^1.1.0",
    "ollama": "^0.5.0",
    "onnxruntime-node": "^1.25.1",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.58.2",
    "potrace": "^2.1.8",
    "pptxgenjs": "4.0.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remotion": "^4.0.451",
    "tesseract.js": "^5.1.1",
    "three": "^0.184.0",
    "typescript": "^5.3.3",
    "web-push": "^3.6.7",
    "ws": "^8.16.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^20.11.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "eslint": "^8.57.0",
    "rcedit": "^4.0.1",
    "tsx": "^4.7.0"
  }
}
